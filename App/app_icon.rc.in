IDI_APP_ICON ICON "@BSSAS_APP_ICON_ICO@"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @BSSAS_APP_VERSION_RC@
 PRODUCTVERSION @BSSAS_APP_VERSION_RC@
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName", "@BSSAS_ORGANIZATION_NAME@\0"
            VALUE "FileDescription", "@BSSAS_APP_DISPLAY_NAME@\0"
            VALUE "FileVersion", "@BSSAS_APP_VERSION@\0"
            VALUE "InternalName", "@BSSAS_EXECUTABLE_NAME@\0"
            VALUE "OriginalFilename", "@BSSAS_EXECUTABLE_FILENAME@\0"
            VALUE "ProductName", "@BSSAS_APP_DISPLAY_NAME@\0"
            VALUE "ProductVersion", "@BSSAS_APP_VERSION@\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
